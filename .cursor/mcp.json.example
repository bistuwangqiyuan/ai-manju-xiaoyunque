{
  "$schema": "https://docs.cursor.com/schemas/mcp.json",
  "$comment": "项目级 火山引擎 + 阿里云 MCP — 用 setup_volc_mcp.ps1 / setup_aliyun_mcp.ps1 一键填入 AKSK; 或手动改 env 字段",
  "mcpServers": {
    "volc-tos": {
      "$comment": "TOS 对象存储 — 操作视频/封面/字幕等媒体资源 (S3 兼容)",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/volcengine/mcp-server#subdirectory=server/mcp_server_tos",
        "mcp-server-tos"
      ],
      "env": {
        "VOLCENGINE_ACCESS_KEY": "",
        "VOLCENGINE_SECRET_KEY": "",
        "VOLCENGINE_REGION": "cn-beijing",
        "TOS_ENDPOINT": "https://tos-cn-beijing.volces.com",
        "TOS_BUCKET": ""
      }
    },
    "volc-vefaas": {
      "$comment": "veFaaS 函数计算 — 管理 serverless 函数/触发器/版本",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/volcengine/mcp-server#subdirectory=server/mcp_server_vefaas_function",
        "mcp-server-vefaas-function"
      ],
      "env": {
        "VOLCENGINE_ACCESS_KEY": "",
        "VOLCENGINE_SECRET_KEY": "",
        "VOLCENGINE_REGION": "cn-beijing"
      }
    },
    "volc-cdn": {
      "$comment": "CDN 智能分析 — 查询 CDN 用量/缓存命中/带宽分布",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/volcengine/mcp-server#subdirectory=server/mcp_server_cdn",
        "mcp_cdn"
      ],
      "env": {
        "VOLCENGINE_ACCESS_KEY": "",
        "VOLCENGINE_SECRET_KEY": "",
        "VOLCENGINE_REGION": "cn-beijing"
      }
    },
    "volc-imagex": {
      "$comment": "veImageX 智能图片 — 封面/缩略图处理、水印、AIGC 标识",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/volcengine/mcp-server#subdirectory=server/mcp_server_veimagex",
        "mcp-server-veimagex"
      ],
      "env": {
        "VOLCENGINE_ACCESS_KEY": "",
        "VOLCENGINE_SECRET_KEY": "",
        "VOLCENGINE_REGION": "cn-beijing"
      }
    },
    "volc-seedream": {
      "$comment": "Doubao Seedream 4.5 文生图 (用项目方舟 API Key, 无需 AKSK)",
      "command": "npx",
      "args": [
        "-y",
        "@hongxianzhi/seedream-image-mcp",
        "--ark-key=ARK_KEY_PLACEHOLDER",
        "--ark-model=doubao-seedream-4-5-251128",
        "--ark-endpoint=https://ark.cn-beijing.volces.com/api/v3/images/generations"
      ]
    },
    "volc-jimeng": {
      "$comment": "即梦 4.0 文生图 (火山方舟官方直连; 用 ARK_API_KEY)",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Ceeon/jimeng-mcp-volcengine",
        "jimeng-mcp-volcengine"
      ],
      "env": {
        "ARK_API_KEY": "",
        "JIMENG_OUTPUT_DIR": "./data/mcp-out/jimeng"
      }
    },
    "aliyun-ops": {
      "$comment": "★ 阿里云 CloudOps (官方旗舰) — 全栈管理 ECS/OSS/VPC/RDS/CloudMonitor/OOS",
      "command": "uvx",
      "args": [
        "alibaba-cloud-ops-mcp-server@latest"
      ],
      "timeout": 600,
      "env": {
        "ALIBABA_CLOUD_ACCESS_KEY_ID": "",
        "ALIBABA_CLOUD_ACCESS_KEY_SECRET": ""
      }
    },
    "aliyun-rds": {
      "$comment": "阿里云 RDS OpenAPI — 关系型数据库 MySQL/PG/SQLServer 管理",
      "command": "uvx",
      "args": [
        "alibabacloud-rds-openapi-mcp-server@latest"
      ],
      "env": {
        "ALIBABA_CLOUD_ACCESS_KEY_ID": "",
        "ALIBABA_CLOUD_ACCESS_KEY_SECRET": ""
      }
    },
    "aliyun-fc": {
      "$comment": "阿里云函数计算 FC3.0 — serverless 函数 + 触发器, 国内对标 AWS Lambda",
      "command": "uvx",
      "args": [
        "alibabacloud-fc-mcp-server@latest"
      ],
      "env": {
        "ALIBABA_CLOUD_ACCESS_KEY_ID": "",
        "ALIBABA_CLOUD_ACCESS_KEY_SECRET": "",
        "ALIBABA_CLOUD_REGION": "cn-hangzhou"
      }
    },
    "aliyun-observability": {
      "$comment": "阿里云可观测 — SLS 日志服务 + CMS 云监控, 排查线上问题",
      "command": "uvx",
      "args": [
        "alibabacloud-observability-mcp-server@latest"
      ],
      "env": {
        "ALIBABA_CLOUD_ACCESS_KEY_ID": "",
        "ALIBABA_CLOUD_ACCESS_KEY_SECRET": "",
        "ALIBABA_CLOUD_REGION": "cn-hangzhou"
      }
    },
    "aliyun-bailian-websearch": {
      "$comment": "百炼联网搜索 — 托管 streamable-http; 仅需 DashScope API Key (sk-xxx); 帮 AI 实时联网",
      "type": "streamable-http",
      "url": "https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp",
      "headers": {
        "Authorization": "Bearer DASHSCOPE_API_KEY_PLACEHOLDER"
      }
    }
  }
}