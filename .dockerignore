# Root-level .dockerignore (build context = repo root)
# 只用最保守的模式，避免 BuildKit 版本差异
# 注意：Dockerfile 显式 COPY backend/requirements.txt 和 backend/app
# 所以即便这里少排除点东西，也不会进镜像

# 前端整个目录
web

# Python 缓存（任意深度）
__pycache__
*.pyc
*.pyo
*.pyd

# 虚拟环境
.venv
venv
env

# 本地数据/日志
*.db
*.sqlite
*.log
smoke.db
smoke.log
data.db

# 本地 .env（生产用 Railway Variables）
.env
.env.local
.env.development
.env.production
backend/.env
backend/.env.local

# 工程文档（不进镜像）
*.md

# 原 AI 流水线目录（接入真实渲染前不需要）
prompts
pilot
config
compliance
tests
prompt
data

# Storage 容器内自己建
backend/storage

# Git / IDE / OS
.git
.gitignore
.gitattributes
.DS_Store
.claude
.vercel
node_modules
