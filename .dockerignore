# =============================================================================
# Root .dockerignore — applied to ALL Dockerfiles built from repo root context
#
# 设计原则:
#   - 只排除「绝对不应进镜像」的东西 (caches, secrets, build artifacts)
#   - 业务源码 (web/, prompts/, config/, compliance/, backend/, src/) 不排除,
#     因为 Dockerfile.allinone 和 Dockerfile.vefaas 都 COPY 它们
#   - 单独的子 Dockerfile (如 backend/Dockerfile.api) 可放置 backend/.dockerignore
# =============================================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.benchmarks/
.coverage*
htmlcov/
.tox/

# --- Node ---
node_modules/
web/node_modules/
.next/
web/.next/
*.tsbuildinfo
**/dist/
**/build/

# --- 虚拟环境 ---
.venv/
venv/
env/
.pyenv/

# --- 本地数据 / 日志 / 数据库 ---
*.db
*.sqlite
*.sqlite3
*.log
data/
backend/storage/
backend/data/
storage/

# --- 本地 .env (生产用 GitHub Secrets / VeFaaS 环境变量) ---
.env
.env.*
!.env.example
!.env.cn.example
backend/.env
backend/.env.*

# --- Git / IDE / OS / Cursor ---
.git/
.gitignore
.gitattributes
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/
.claude/
.vercel/

# --- 临时 / 构建产物 ---
*.tmp
*.bak
*.swp
*.zip
*.tar.gz
release/
dist/

# --- 测试 (镜像里不跑测试) ---
tests/
test_*.py
*_test.py

# --- 文档 (不进镜像) ---
docs/
*.md
!README.md

# --- 部署元数据 (递归构建会出现) ---
deploy/cn-serverless/build/
deploy/cn-volc-vefaas/build/
