# Root-level .dockerignore for Railway builds (context = repo root)
# 让镜像只包含 backend/，剩下的都排除掉

# Frontend：用不上
web/

# Backend 局部产物
backend/.venv
backend/__pycache__
backend/**/__pycache__
backend/**/*.pyc
backend/*.db
backend/*.sqlite
backend/smoke.log
backend/data.db
backend/storage/*
!backend/storage/.gitkeep
backend/.env
backend/.env.*
!backend/.env.example

# 工程文档（不入镜像）
*.md
final-plan.md
content_report.md
research-2026-05.md
tech.md
novel-无限恐怖.md

# 原项目其余目录（暂不需要进镜像；接入真实流水线时再放开 src/）
prompts/
pilot/
config/
compliance/
tests/
prompt
data/

# 通用
.git
.gitignore
.gitattributes
.DS_Store
*.log
.claude/
.vercel/
node_modules/
