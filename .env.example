# =============================================================================
# AI 漫剧产线 v5 — API Key 清单（按依赖优先级排序）
# =============================================================================
# 复制本文件为 .env，按下方变量填入对应 API Key。
# 必备最低 8 个 Key（标记 ★），其余可在 D7-D9 高光精修阶段再补。

# ===== ★ 火山引擎（核心，小云雀 / Seedance / Seedream / 即梦 / 豆包） =====
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ARK_API_KEY=                     # 豆包 Seed 1.6 系列
DOUBAO_API_KEY=                       # 豆包对话（如使用 OpenAI 兼容接口）
DOUBAO_TTS_APPID=                     # 豆包 Seed-TTS 2.0 + ICL
DOUBAO_TTS_TOKEN=

# ===== ★ Anthropic Claude Opus 4.7（主笔） =====
# 可选 1：官方端点 直接放 ANTHROPIC_API_KEY 即可
# 可选 2：第三方代理（pure100.org GLM 等）→ 同时设置 BASE_URL + AUTH_TOKEN
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=                    # 例：https://www.pure100.org（代理时填，官方端点留空）
ANTHROPIC_AUTH_TOKEN=                  # 代理用 Bearer token；同时镜像写到 ANTHROPIC_API_KEY 兼容 SDK
ANTHROPIC_MODEL=claude-opus-4-7        # 默认主笔模型
# Claude Code CLI 专用（用代理时建议都开）
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_ATTRIBUTION_HEADER=0

# ===== ★ DeepSeek V4-Pro（1M 上下文事件抽取） =====
DEEPSEEK_API_KEY=

# ===== ★ Google Gemini 2.5 Pro（JSON schema 校验） =====
GEMINI_API_KEY=

# ===== ★ ElevenLabs（BGM / SFX / Multilingual TTS） =====
ELEVENLABS_API_KEY=

# ===== ★ Fal.ai（InfiniteYou / Wan-FLF / FLUX Kontext） =====
FAL_API_KEY=

# ===== ★ Replicate（PuLID 多角色锁） =====
REPLICATE_API_TOKEN=

# ===== Google Vertex AI（Veo 3.1 高光集精修，D7-D9 再补） =====
GOOGLE_CLOUD_PROJECT=
GOOGLE_ACCESS_TOKEN=
GOOGLE_VERTEX_LOCATION=us-central1

# ===== OpenAI（Sora 2 Pro 仅 ep09 封神镜头，D8 再补） =====
OPENAI_API_KEY=

# ===== Runway（Aleph V2V 跨集风格洗一） =====
RUNWAY_API_KEY=

# ===== Hedra（Character-3 近景台词 lip-sync） =====
HEDRA_API_KEY=

# ===== MiniMax（Speech 2.5 HD 情感张力补强） =====
MINIMAX_API_KEY=

# ===== Suno（v5.5 Premier 主题曲，可选） =====
SUNO_API_KEY=

# ===== 阿里云百炼（Wan 2.2-Animate 武打动作迁移，可选） =====
DASHSCOPE_API_KEY=

# ===== Kling（可灵 2.5 备用动作戏，可选） =====
KLING_API_KEY=

# ===== 网易天音（中文古风 BGM，可选） =====
NETEASE_TIANYIN_API_KEY=

# =============================================================================
# 存储后端配置
# =============================================================================
STORAGE_BACKEND=local                 # local / s3 / tos / oss
STORAGE_ROOT=./data/storage

# 如使用 S3 / TOS / OSS，需额外配置：
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# =============================================================================
# 监控与告警
# =============================================================================
SKYLARK_REQ_KEY_CACHE=./data/.skylark_req_key.json
LOG_LEVEL=INFO
