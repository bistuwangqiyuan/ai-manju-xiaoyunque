# AI 漫剧产线 — gitignore

# ===== Secrets =====
.env
.env.local
.env.bak*
.env.simple
deploy/cn-serverless/.env
deploy/cn-serverless/.env.simple
*.pem
*.key

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ===== Runtime data =====
data/storage/
data/episodes/
data/_debug/
data/runs/
data/test_*.db
data/test_*_storage/
data/smoke*
data/filing/
data/test_storage/
data/test_backend.db
data/test.db
*.sqlite
*.sqlite3
# 含 .bak_/_FINAL_/_R*_ 等所有变体
data/pilot_short_skylark*
# 源小说原文+衍生 storyboard（不入版权材料）
data/novel-*
# api_health / skylark_health 等运行日志
data/*.log
data/characters/*/
data/scenes/*/
data/style/reference_jpgs/
data/voices/
data/covers/
data/master_4k/
data/work/
data/.skylark_req_key.json
data/refs/
logs/

# ===== IDE =====
.claude/
# .cursor/ 下大部分忽略, 但 mcp.json.example 入库 (实际 mcp.json 由 setup 脚本生成, 含真实密钥)
.cursor/*
!.cursor/mcp.json.example
.vscode/
.idea/
*.swp

# ===== OS =====
.DS_Store
Thumbs.db
*.log
smoke.*

# ===== Build / staging artifacts =====
deploy/cloudfn-pkg/
deploy/cloudfn-minimal/
deploy/tmp-minimal/
# cloudfunctions/xyq-api is a staging copy of deploy/cloudfn-slim/ created at deploy time
cloudfunctions/xyq-api/app/
cloudfunctions/xyq-api/src/
cloudfunctions/xyq-api/config/
cloudfunctions/xyq-api/prompts/
cloudfunctions/xyq-api/tools/
cloudfunctions/xyq-api/compliance/
cloudfunctions/xyq-api/web/
cloudfunctions/xyq-api/requirements.slim.txt
# Local databases / temp dumps
data/local_e2e.db
data/verify_local.db
data/tmp_create_cloudrun_env.json
data/observability/real_e2e_first_episode.mp4
# Stray PowerShell redirect file
web/-w
# Volcengine sample mp4 download cache (duplicated under web/public/samples/)
sample/

# 多段拼接的中间分段视频（已合并入最终 mp4，不需要入库）
web/public/samples/*_seg[0-9].mp4

# t2i / pipeline 日志
/gen_*.log
