# ============================================================
# 后端环境变量 - 部署到 Railway / Render / Fly.io 时填入
# ============================================================

# ---- 必填 ----
# JWT 签名密钥（随便生成 32 位以上随机字符串，不可泄露）
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# 数据库 URL
# 本地：sqlite:///./data.db
# Railway 上加 Postgres 插件后自动生成 DATABASE_URL
DATABASE_URL=sqlite:///./data.db

# 允许的前端来源（Vercel 部署后的域名），逗号分隔
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# 站点 URL（用于 Stripe 回调）
SITE_URL=http://localhost:3000

# ---- 计费 ----
# 注册赠送的体验金（分）¥100 = 10000 分（刚好覆盖 1 集试看）
SIGNUP_BONUS_CENTS=10000

# ---- Stripe（可选）----
# 留空将使用 mock 充值流（直接加额度，方便联调）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- AI 渲染（接入真实流水线时填入）----
# 留空则 worker 走 mock 模式，返回示例视频
# 全部留空 + 设置 MOCK_MODE=1 可获得完全离线的端到端体验
MOCK_MODE=1

# 火山引擎（Skylark Agent 2.0 + Seedream 5 + Seedance + 即梦 4.6）
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ARK_API_KEY=
DOUBAO_API_KEY=
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=

# 主笔 LLM
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-7-20260413
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# 视频生成与修复
FAL_API_KEY=                # FLUX Kontext / Wan FLF / InfiniteYou
REPLICATE_API_TOKEN=        # PuLID 多角色锁
RUNWAY_API_KEY=             # Aleph V2V 风格迁移
HEDRA_API_KEY=              # Character-3 lip sync
DASHSCOPE_API_KEY=          # 阿里通义 / Wan 2.2-Animate
KLING_API_KEY=              # 可灵 2.5 备用
OPENAI_API_KEY=             # Sora 2 Pro 高光集
GOOGLE_CLOUD_PROJECT=
GOOGLE_ACCESS_TOKEN=
GOOGLE_VERTEX_LOCATION=us-central1

# 配音 / BGM / SFX
ELEVENLABS_API_KEY=          # Multilingual v3 + BGM + SFX
MINIMAX_API_KEY=             # Speech 2.5 HD
SUNO_API_KEY=                # 主题曲（可选）
NETEASE_TIANYIN_API_KEY=     # 中文古风 BGM（可选）

# ---- 合规与节流 ----
SKIP_CINEMATIC_MASTER=0      # 1=跳过精剪（无 ffmpeg 时使用）
FORCE_MOCK_SCORER=0          # 1=7-dim 评分器跳过真实 VLM
FORCE_MOCK_THEME=0           # 1=theme→novel 走 mock
FORCE_MOCK_NOVELTY=0         # 1=版权 LLM 检测走启发式
FORCE_MOCK_MARKETING=0       # 1=营销文案走启发式
FORCE_MOCK_CONTINUATION=0    # 1=剧情续写走启发式
FORCE_MOCK_RESTYLE=0         # 1=风格迁移走 mock
FORCE_MOCK_TRANSLATE=0       # 1=字幕翻译走 mock
FORCE_MOCK_REDRAW=0          # 1=批量转绘走 mock

# ---- 存储（可选，留空则用本地 ./storage）----
STORAGE_DIR=./storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ---- 系统 ----
LOG_LEVEL=INFO
WORKER_POLL_INTERVAL=2
