# ============================================================
# 后端环境变量 - 部署到 Railway / Render / Fly.io 时填入
# ============================================================

# ---- 必填 ----
# JWT 签名密钥（随便生成 32 位以上随机字符串，不可泄露）
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# 数据库 URL
# 本地：sqlite:///./data.db
# Railway 上加 Postgres 插件后自动生成 DATABASE_URL
DATABASE_URL=sqlite:///./data.db

# 允许的前端来源（Vercel 部署后的域名），逗号分隔
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# 站点 URL（用于 Stripe 回调）
SITE_URL=http://localhost:3000

# ---- 计费 ----
# 注册赠送的体验金（分）¥100 = 10000 分（刚好覆盖 1 集试看）
SIGNUP_BONUS_CENTS=10000

# ---- Stripe（可选）----
# 留空将使用 mock 充值流（直接加额度，方便联调）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- AI 渲染（接入真实流水线时填入）----
# 留空则 worker 走 mock 模式，返回示例视频
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ARK_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
FAL_API_KEY=

# ---- 存储（可选，留空则用本地 ./storage）----
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ---- 系统 ----
LOG_LEVEL=INFO
WORKER_POLL_INTERVAL=2
