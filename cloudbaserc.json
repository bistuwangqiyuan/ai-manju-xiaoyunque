{
  "version": "2.0",
  "envId": "cursoraicode-5g67ezfl8a1891da",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "functions": [
    {
      "name": "xyq-api",
      "handler": "index.main_handler",
      "timeout": 60,
      "memorySize": 256,
      "runtime": "Python3.9",
      "installDependency": false,
      "envVariables": {
        "MOCK_MODE": "1",
