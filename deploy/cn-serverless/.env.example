# =============================================================================
# 小云雀 AI 漫剧 · 无服务器部署环境变量
#
# 用途：本机调试 deploy.sh / deploy.ps1 时读取这些值再注入到 CloudBase / SCF / EdgeOne
#       生产环境的密钥仍存于各平台控制台，本文件 **不要提交**！
# =============================================================================

# ---- 1. 腾讯云账号 ----
# 子账号 AccessKey (推荐) 或主账号 AK/SK
TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENT_REGION=ap-shanghai

# ---- 2. CloudBase 环境 ----
# 在 https://console.cloud.tencent.com/tcb 创建 "按量计费" 环境后填入
ENV_ID=xyq-prod-1g123ab456cd
BACKEND_SERVICE_NAME=xyq-backend

# ---- 3. 数据库 ----
# 腾讯云 PostgreSQL Serverless: https://console.cloud.tencent.com/postgres
# 创建实例后取 "内网连接地址"
DATABASE_URL=postgresql+psycopg2://xyq:STRONG_PASSWORD@gz-postgres-xxxx.sql.tencentcdb.com:5432/xyq

# ---- 4. 安全密钥 (用 `openssl rand -base64 48` 生成) ----
JWT_SECRET=请改为强随机64字符
INTERNAL_API_SECRET=请改为强随机64字符

# ---- 5. URL 配置 ----
# CloudBase 部署后会拿到一个公网域名，回填到 SITE_URL / CORS_ORIGINS
SITE_URL=https://xyq-frontend.edgeone.app
PUBLIC_URL=https://xyq-frontend.edgeone.app
CORS_ORIGINS=https://xyq-frontend.edgeone.app
BACKEND_URL=https://xyq-backend-xxxxx-1300000000.ap-shanghai.run.tcloudbase.com

# ---- 6. 腾讯云 COS (对象存储, 存视频/封面) ----
# https://console.cloud.tencent.com/cos
COS_REGION=ap-shanghai
COS_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
COS_BUCKET=xyq-prod-1300000000
COS_SECRET_ID=AKIDxxxx
COS_SECRET_KEY=xxxx
COS_PUBLIC_BASE_URL=https://xyq-prod-1300000000.cos.ap-shanghai.myqcloud.com

# ---- 7. AI 流水线 Key (按需; 缺失则走 mock) ----
MOCK_MODE=0
VOLC_ARK_API_KEY=
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
DOUBAO_API_KEY=
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7-20260413
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
