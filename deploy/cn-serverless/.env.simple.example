# =============================================================================
# 小云雀 AI 漫剧 · 极简 Serverless 部署 · 只需填 3 个字段
#
# 用法:
#   cp .env.simple.example .env.simple
#   编辑 .env.simple 填入 3 个值
#   bash deploy_simple.sh   (或  Windows: .\deploy_simple.ps1)
# =============================================================================

# ---- 必填 1: 腾讯云 SecretId (格式: AKID 开头的 36 字符) ----
# 获取: https://console.cloud.tencent.com/cam/capi → 新建密钥
TENCENT_SECRET_ID=

# ---- 必填 2: 腾讯云 SecretKey (32 字符随机串) ----
TENCENT_SECRET_KEY=

# ---- 必填 3: CloudBase 环境 ID (格式: xxx-1g12345abc) ----
# 获取: https://console.cloud.tencent.com/tcb → 创建按量计费环境 → 复制环境 ID
ENV_ID=

# ---- 可选: 区域 (默认上海) ----
TENCENT_REGION=ap-shanghai

# ---- 可选: AI Keys (留空 → 走 mock 模式, 仍可体验全流程) ----
VOLC_ARK_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DOUBAO_API_KEY=

# 以下不需要填, deploy_simple 脚本会自动生成 / 拼装:
#   JWT_SECRET          → 自动生成 48 字节随机
#   INTERNAL_API_SECRET → 自动生成 48 字节随机
#   SITE_URL            → 部署完成后自动回填
#   DATABASE_URL        → 容器内置 SQLite, 无需配置
#   COS_*               → 不需要, 文件存在容器持久卷
