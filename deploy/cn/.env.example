# ============================================================
# 小云雀 AI 漫剧 · 国内部署环境变量模板
#
# 操作：cp .env.example .env  然后填入真实值
#
# 必填（4 项）：
#   - POSTGRES_PASSWORD
#   - JWT_SECRET
#   - DOMAIN
#   - ACME_EMAIL（DOMAIN 是真实域名时必填，用于申请 Let's Encrypt 证书）
#
# 可选：所有 *_API_KEY 不填即走 mock 模式，仍可正常体验全流程
# ============================================================

# -------- 1. 基础设施 --------
POSTGRES_PASSWORD=请改成强密码
JWT_SECRET=请改成32位以上随机字符串
TZ=Asia/Shanghai
LOG_LEVEL=INFO
WORKER_CONCURRENCY=2

# -------- 2. 域名 / HTTPS --------
# 如有域名（推荐）：填域名，Caddy 自动签发 HTTPS 证书
#   DOMAIN=manju.example.com
# 如暂时直接 IP 访问（不需要 HTTPS）：保持默认 :80
DOMAIN=:80
ACME_EMAIL=admin@example.com
SITE_URL=http://your-server-ip
PUBLIC_URL=http://your-server-ip
CORS_ORIGINS=*

# -------- 3. AI 流水线 API Key（按需填写；缺失则走对应 mock）--------
# 火山引擎（核心引擎，小云雀 Agent 2.0 / 豆包 / Seedream）
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_ARK_API_KEY=
DOUBAO_API_KEY=
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=

# Anthropic Claude（剧本 / 营销文案）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-7-20260413

# 其它 LLM / 视频 / 音频
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
HEDRA_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
SUNO_API_KEY=
KLING_API_KEY=
NETEASE_TIANYIN_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_ACCESS_TOKEN=

# -------- 4. Mock 开关（缺 Key 时强制走 mock；不缺 Key 也可以保留 mock 兜底）--------
MOCK_MODE=0
FORCE_MOCK_SCORER=0
FORCE_MOCK_THEME=0
FORCE_MOCK_NOVELTY=0
FORCE_MOCK_MARKETING=0
FORCE_MOCK_CONTINUATION=0
FORCE_MOCK_TRANSLATE=0
FORCE_MOCK_WAN_ANIMATE=1
FORCE_MOCK_TTS_MINIMAX=1
USE_REAL_COVER=1
USE_REAL_UPSCALER=0

# -------- 5. 前端语言（zh-CN / zh-Hant / en）--------
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN
