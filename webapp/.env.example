# Volcengine 火山方舟 — Skylark Agent 2.0 (Pippit IV2V with vinput) 凭证
# 由 https://console.volcengine.com/iam 创建 IAM 账号获取 AK/SK
VOLC_ACCESS_KEY=your-volcengine-access-key-here
VOLC_SECRET_KEY=your-volcengine-secret-key-here

# (可选) AIGC 隐式标识 — 用于 GB/T 45438-2025 落标
# 默认值已编码在代码中，可不填
AIGC_CONTENT_PRODUCER=
AIGC_CONTENT_PROPAGATOR=

# (可选) 限流：每 IP 每天最大生成次数（防止恶意滥用）
# 默认无限。建议生产环境用 Upstash Redis 实现
DAILY_GENERATION_LIMIT=

# 站点元信息
NEXT_PUBLIC_SITE_NAME=云雀漫剧
NEXT_PUBLIC_SITE_TAGLINE=AI 国漫一键生成
