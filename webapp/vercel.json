{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["hkg1", "sin1"],
  "functions": {
    "app/api/generate/route.ts": { "maxDuration": 60 },
    "app/api/status/[taskId]/route.ts": { "maxDuration": 30 },
    "app/api/proxy-video/route.ts": { "maxDuration": 60 }
  },
  "env": {
    "VOLC_ACCESS_KEY": "@volc-access-key",
    "VOLC_SECRET_KEY": "@volc-secret-key"
  }
}
